# Токен Discord бота (обязательно)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# OpenAI API ключ (обязательно)
OPENAI_API_KEY=your_openai_api_key_here

# Базовый URL OpenAI (опционально, по умолчанию официальный OpenAI)
# Для Replit AI Integrations: укажи AI_INTEGRATIONS_OPENAI_BASE_URL
# OPENAI_BASE_URL=https://...
